{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":automergeMinor",
    "group:allNonMajor"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["at any time"],
  "prConcurrentLimit": 5,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Go minor/patch - automerge",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Go major - manual review",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major"]
    },
    {
      "description": "npm minor/patch - automerge",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "npm major - manual review",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "npm", "major"]
    },
    {
      "description": "Docker minor/patch - automerge",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Docker major - manual review",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "docker", "major"]
    },
    {
      "description": "GitHub Actions minor/patch - automerge",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "GitHub Actions major - manual review",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": false,
      "labels": ["dependencies", "github-actions", "major"]
    },
    {
      "description": "GoReleaser minor/patch - automerge",
      "matchPackageNames": ["goreleaser/goreleaser"],
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "golangci-lint minor/patch - automerge",
      "matchPackageNames": ["golangci/golangci-lint"],
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "description": "govulncheck minor/patch - automerge (skip v1.4.0: generics panic)",
      "matchPackageNames": ["golang.org/x/vuln"],
      "matchManagers": ["regex"],
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch"],
      "allowedVersions": "<1.4.0 || >1.4.0"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track golangci-lint version in go install workflow steps",
      "managerFilePatterns": ["/\\.github/workflows/[^/]+\\.ya?ml$/"],
      "matchStrings": [
        "golangci-lint/v2/cmd/golangci-lint@(?<currentValue>v[\\d.]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "golangci/golangci-lint",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Track govulncheck version in go install workflow steps",
      "managerFilePatterns": ["/\\.github/workflows/[^/]+\\.ya?ml$/"],
      "matchStrings": [
        "golang.org/x/vuln/cmd/govulncheck@(?<currentValue>v[\\d.]+)"
      ],
      "datasourceTemplate": "go",
      "depNameTemplate": "golang.org/x/vuln",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Track GoReleaser version in release workflow",
      "managerFilePatterns": ["/\\.github/workflows/[^/]+\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=goreleaser/goreleaser\\n\\s+version: (?<currentValue>[^\\s\"]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "goreleaser/goreleaser",
      "versioningTemplate": "semver"
    }
  ],
  "gomod": {
    "postUpdateOptions": ["gomodTidy"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
